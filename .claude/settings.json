{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .claude/hooks/format.js",
                        "timeout": 30,
                        "statusMessage": "Formatting…"
                    }
                ]
            }
        ]
    }
}
